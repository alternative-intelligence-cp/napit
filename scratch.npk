use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-str/src/nitpick_str.npk".*;
use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-fs/src/nitpick_fs.npk".*;

pub func:main = int32() {
    string:content = raw fs_read_file("/proc/self/cmdline");
    string:result = raw Str.replace_all(content, string_from_char(0i8), "|");
    print(result);
    print("\n");
    exit 0i32;
};
